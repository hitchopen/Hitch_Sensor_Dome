# macOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Thumbnails
Thumbs.db
ehthumbs.db

# OpenSCAD backup/cache files
*.scad~
*.scad.bak

# Python cache
__pycache__/
*.pyc

# GLIM build artifacts (do not commit compiled output)
GLIM_plusplus/build/
GLIM_plusplus/install/
GLIM_plusplus/log/
# Defensive: catch any accidental nested copy of glim/ inside GLIM_plusplus/config/.
GLIM_plusplus/config/glim/

# GLIM map output (large; produced per session)
glim_maps/

# Recording sessions (large MCAP bags — keep out of git).
# The recording/data/ folder itself is tracked via .gitkeep, but
# every session_* subdir written by sensor_recorder.py is ignored.
recordings/
recording/sessions/
recording/data/*
!recording/data/.gitkeep

# Office documents (generated review reports, drafts, etc. — do not commit)
*.docx
*.doc
~$*.docx
~$*.doc
*.xlsx
*.xls
~$*.xlsx
~$*.xls
*.pptx
*.ppt
~$*.pptx
~$*.ppt
