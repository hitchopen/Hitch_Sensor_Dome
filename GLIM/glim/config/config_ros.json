{
  /*** ROS-related config ***/
  // --- Backend modules ---
  // If both local and global mapping are disabled, odometry estimation runs.
  // enable_local_mapping   : Enable local mapping module
  // enable_global_mapping  : Enable global mapping module
  //
  // --- Points config ---
  // keep_raw_points        : Keep raw points in the map (required for only extension modules)
  //
  // --- IMU config ---
  // imu_time_offset        : Time offset for IMU data (in seconds)
  // acc_scale              : Accelerometer scale factor (Set to 9.80665 for Livox sensors)
  //
  // --- TF config ---
  // GLIM publishes TF subtrees "map -> odom -> base_frame" and "imu -> lidar".
  // imu_frame_id           : IMU frame ID (If blank, auto-detected from IMU topic)
  // lidar_frame_id         : LiDAR frame ID (If blank, auto-detected from points topic)
  // base_frame_id          : Base frame ID. If blank, IMU frame ID is used.
  // odom_frame_id          : Odometry frame ID
  // map_frame_id           : Map frame ID
  // publish_imu2lidar      : If false, do not publish "imu -> lidar" TF
  // tf_time_offset         : Time offset for TF data (in seconds)
  //
  // --- Extension modules ---
  // extension_modules      : List of extension modules to load
  //
  // --- Topics ---
  // imu_topic              : IMU topic
  // points_topic           : Points topic
  // image_topic            : Image topic (required for only extension modules)
  //
  // --- QoS options ---
  // imu_qos                : QoS options for IMU topic subscription.
  //   profile              : Builtin QoS profile name. Could be one of the following:
  //                          default, system_default, sensor_data, services_default, parameters, parameter_events
  //   depth                : Size of the message queue.
  //   durability           : Durability QoS policy setting. Could be one of the following:
  //                          system_default, transient_local, volatile
  //   reliability          : Reliabiilty QoS policy setting. Could be one of the following:
  //                          system_default, reliable, best_effort
  //   history              : History QoS policy setting. Could be one of the following:
  //                          system_default, keep_last, keep_all
  // points_qos             : QoS options for points topic subscription. See imu_qos for details.
  // image_qos              : QoS options for image topic subscription. See imu_qos for details.
  "glim_ros": {
    // Backend modules
    "enable_local_mapping": true,
    "enable_global_mapping": true,
    // Points config
    "keep_raw_points": false,
    // IMU config
    "imu_time_offset": 0.00,
    "points_time_offset": 0.0,
    // Atlas Duo (Point One Nav) outputs linear acceleration in m/s² natively,
    // so leave the scale factor at 1.0. The auto-detect mode (0.0) was
    // explicitly recommended away from in the upstream Claude tuning review.
    "acc_scale": 1.0,
    // TF config — body frame for the global map.
    //
    // base_frame_id = "imu_link" makes GLIM build the map relative to the
    // Atlas Duo Center of Navigation (the parent of every transform in
    // config/sensor_dome_tf.yaml). Per-vehicle calibrations can then publish
    // a single static "imu_link → base_link" transform downstream — the map
    // itself stays vehicle-agnostic and reusable across platforms.
    //
    // imu_frame_id and lidar_frame_id are pinned to match the static-TF
    // chain in sensor_dome_tf.yaml so GLIM's auto-detect can't drift if a
    // driver renames its frame.
    "imu_frame_id": "imu_link",
    "lidar_frame_id": "lidar_front_link",
    "base_frame_id": "imu_link",
    "odom_frame_id": "odom",
    "map_frame_id": "map",
    "publish_imu2lidar": true,
    "tf_time_offset": 1e-6,
    // Extension modules.
    // libimu_validator.so is enabled by default during bring-up so any
    // gravity / scale / extrinsic mismatch surfaces in the GLIM viewer
    // before it corrupts the map. Disable it once the rig has been
    // characterized and the IMU validator reports clean for several runs.
    "extension_modules": [
      "libmemory_monitor.so",
      "libstandard_viewer.so",
      "librviz_viewer.so",
      "libgnss_global.so",
      "libimu_validator.so"
    ],
    // Topics — Hitch Sensor Dome conventions.
    //   /imu/data               fusion_engine_driver (sensor_msgs/Imu @ 200 Hz)
    //   /robin_w_front/points   seyond driver, the primary stitched cloud.
    //                           rear-left and rear-right are merged into
    //                           this topic by the lidar_concat block in
    //                           config_sensors.json.
    "imu_topic": "/imu/data",
    "points_topic": "/robin_w_front/points",
    "image_topic": "/cam_front_left/image_raw",
    // QoS — match recording/sensor_config.yaml so GLIM can subscribe
    // directly to the live drivers or replay an .mcap bag.
    "imu_qos": {
      "profile": "sensor_data",
      "depth": 1000
    },
    "points_qos": {
      "profile": "sensor_data",
      "reliability": "best_effort"
    },
    "image_qos": {
      "profile": "sensor_data"
    }
  }
}
